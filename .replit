modules = ["web", "php-8.2", "nodejs-20", "bash"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Laravel Server"

[[workflows.workflow]]
name = "Laravel Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "./start-server.sh"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["php", "-S", "0.0.0.0:8080", "-t", "public"]

[userenv]

[userenv.shared]
APP_KEY = "base64:ALVos7BNi2UL0dfSZ7nduc4p9cWwmJXKIEzyGamTWQc="
SESSION_DRIVER = "file"
DB_CONNECTION = "pgsql"
APP_ENV = "local"
APP_DEBUG = "true"
LOG_CHANNEL = "stack"
LOG_LEVEL = "debug"
CACHE_STORE = "file"
